<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提醒設定"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="調整風速、浪高與提醒偏好，資料會儲存在 Room 與 SharedPreferences。"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            style="@style/FormLabel"
            android:text="最大風速警戒值（m/s）" />

        <EditText
            android:id="@+id/editWindLimit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:singleLine="true" />

        <TextView
            style="@style/FormLabel"
            android:text="最大浪高警戒值（m）" />

        <EditText
            android:id="@+id/editWaveLimit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:singleLine="true" />

        <Switch
            android:id="@+id/switchDangerAlert"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="危險等級跳出 AlertDialog"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <Switch
            android:id="@+id/switchOpenLast"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="啟動 App 時自動開啟上次查看漁港"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <Switch
            android:id="@+id/switchPushAlert"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="啟用模擬推播提醒"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="儲存設定"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSettingsBack"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="返回"
            app:cornerRadius="8dp" />
    </LinearLayout>
</ScrollView>
